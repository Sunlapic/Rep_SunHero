///enemy Create
visible = true; // враг видим сразу после создания

// ── ХАРАКТЕРИСТИКИ ВРАГА ──────────────────────────────────
hp = 30 + irandom(20); // текущее HP при спавне: от 30 до 50
max_hp = hp; // максимальное HP равно стартовому
damage = 10; // урон по игроку за один успешный удар
attack_speed = game_get_speed(gamespeed_fps); // кулдаун атаки: 1 раз в секунду при 60 FPS
attack_range = 100; // дистанция атаки по X
attack_height = 100; // допустимая разница по Y для удара
attack_timer = 0; // таймер отката атаки

// ── РЕСПАВН ───────────────────────────────────────────────
is_dead = false; // флаг смерти
death_anim_done = false; // закончилась ли анимация смерти
respawn_delay = 180; // через сколько кадров возрождается: 180 = 3 сек при 60 FPS
respawn_timer = 0; // текущий таймер респавна
spawn_x = 64; // точка респавна по X слева
spawn_y = room_height - 64; // примерная точка респавна по Y, потом можно подогнать вручную

// ── ОБНАРУЖЕНИЕ ИГРОКА ────────────────────────────────────
notice_range = 70; // дистанция, на которой замечает игрока; если мало — увеличь до 200-400
notice_height = 80; // допустимая разница по высоте для обнаружения
target = noone; // текущая цель

// ── БЛУЖДАНИЕ ─────────────────────────────────────────────
wander_speed = 0.8 + random(0.4); // скорость блуждания: от 0.8 до 1.2
chase_speed  = 1.8; // скорость бега за игроком
wander_dir = choose(-1, 1); // направление блуждания: -1 влево, 1 вправо
wander_timer = irandom_range(60, 120); // через сколько кадров сменить решение при блуждании

// ── ФИЗИКА ────────────────────────────────────────────────
vsp = 0; // вертикальная скорость
grav = 0.35; // гравитация
max_fall_speed = 8; // максимум скорости падения

// ── НАГРАДЫ ЗА УБИЙСТВО ───────────────────────────────────
last_attacker = noone;   // кто нанес последний удар
reward_given  = false;   // чтобы награда не выдалась дважды
xp_reward = 10; // сколько опыта даст игроку
gold_reward = irandom_range(1, 5); // сколько золота сразу начислится игроку
gold_drop = irandom_range(2, 6); // запас под выпадение золота на землю

// ── СЛУЖЕБНЫЕ ПЕРЕМЕННЫЕ ──────────────────────────────────
image_xscale = 1; // стартовое направление взгляда
enemy_grounded = false; // поставили ли врага на землю после создания

// ── АНИМАЦИИ СКЕЛЕТА ──────────────────────────────────────
spr_walk = spr_skeleton_warrior_walk; // ходьба
spr_run = spr_skeleton_warrior_run; // бег
spr_dead = spr_skeleton_warrior_dead; // смерть
spr_attack_1 = spr_skeleton_warrior_attack_1; // атака №1
spr_attack_2 = spr_skeleton_warrior_attack_2; // атака №2
spr_attack_3 = spr_skeleton_warrior_attack_3; // атака №3

current_attack_sprite = spr_attack_1; // какой атакой сейчас машет
is_attacking = false; // идёт ли сейчас анимация атаки
attack_hit_done = false; // нанесён ли урон в текущей анимации атаки
attack_hit_frame = 2; // на каком кадре атаки считается попадание; 2 = примерно середина замаха

sprite_index = spr_walk; // стартовый спрайт
image_index = 0; // первый кадр
image_speed = 0.6; // скорость анимации ходьбы
mask_index = spr_walk; // используем одну маску коллизии, чтобы анимации не дёргали хитбокс