/// o_main — Create Event (Событие создания объекта o_main)
/// Здесь инициализируем все переменные и подключаемся к Twitch IRC

// =============================================
// 1. ИНИЦИАЛИЗАЦИЯ TWITCH API
// =============================================
// Инициализируем Twitch API с вашим Client-ID
twitch_init("zuay8duv5c8ujgfq0ioudyimoi85q3");

// =============================================
// 2. ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ ДЛЯ IRC-СОЕДИНЕНИЯ
// =============================================
global.IRC_socket = -1;// Идентификатор TCP-сокета для IRC-подключения
global.irc_ready = false; //Флаг, указывающий, что соединение с Twitch IRC установлено
global.last_irc_activity = current_time;// Время последней активности IRC (для keepalive)
global.irc_reconnect_cd = 0;// Задержка перед повторным подключением (в кадрах)
global.irc_keepalive = 0; // Таймер для keepalive

// =============================================
// 3. ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ ДЛЯ ИГРОКОВ
// =============================================
global.players = ds_map_create(); // Создаём ds_map для хранения всех игроков

// =============================================
// 4. ПЕРЕМЕННЫЕ ДЛЯ ВРАГОВ И UI
// =============================================
enemy_spawn_timer = 0; // Таймер для спавна врагов (в кадрах)
enemy_max = 0; // Максимальное количество врагов на карте

///ТАБЛИЦА ЛИДЕРОВ________________________
sort_mode = 0; // Режим сортировки таблицы игроков (0 = по уровню, 1 = по золоту)
max_rows = 10; // Максимальное количество строк в таблице игроков

// Параметры UI-панели (ширина, отступы, высота заголовка, высота строки)
panel_w = 300;   // Ширина панели
padding = 10;    // Отступы внутри панели
header_h = 26;   // Высота заголовка таблицы
row_h = 18;      // Высота строки таблицы

heard = 0; // Счётчик услышанных команд (не используется в текущей версии)

sent_welcome = false; // Флаг для отслеживания, было ли отправлено приветственное сообщение

// =============================================
// 5. ПОДКЛЮЧЕНИЕ К TWITCH IRC
// =============================================
// Подключаемся к Twitch IRC:
//   - "Sunlapic" - имя канала (без #)
//   - "serjantoss" - имя бота (в нижнем регистре!)
//   - "oauth:2996u..." - OAuth токен (ОБЯЗАТЕЛЬНО с префиксом "oauth:")
twitch_chat_connect("Sunlapic", "serjantoss", "oauth:2996uwe5kso1yul86v5qrn6pbtbbla");

// =============================================
// 6. СОХРАНЕНИЕ КАЖДЫЕ 60 СЕКУНД (например, раз в 60 секунд при 60 FPS)
// =============================================
auto_save_timer = 0;
auto_save_interval = 60 * 60; 